import { createContext, useContext, useState, useEffect } from 'react';

const FileSystemContext = createContext();

export const useFileSystem = () => {
  const context = useContext(FileSystemContext);
  if (!context) {
    throw new Error('useFileSystem must be used within FileSystemProvider');
  }
  return context;
};

export const FileSystemProvider = ({ children }) => {
  const [directoryHandle, setDirectoryHandle] = useState(null);
  const [directoryPath, setDirectoryPath] = useState('');
  const [fileTree, setFileTree] = useState({
    id: 'root',
    name: 'My Workspace',
    type: 'folder',
    children: []
  });

  const [selectedFile, setSelectedFile] = useState(null);
  const [openFiles, setOpenFiles] = useState([]);
  const [citations, setCitations] = useState([]);

  // Check if File System Access API is supported
  const isFileSystemAccessSupported = 'showDirectoryPicker' in window;

  // Load citations from localStorage
  useEffect(() => {
    const savedCitations = localStorage.getItem('citations');
    if (savedCitations) {
      setCitations(JSON.parse(savedCitations));
    }
  }, []);

  useEffect(() => {
    localStorage.setItem('citations', JSON.stringify(citations));
  }, [citations]);

  // Open a directory from the PC
  const openDirectory = async () => {
    if (!isFileSystemAccessSupported) {
      alert('File System Access API is not supported in this browser. Please use Chrome or Edge.');
      return;
    }

    try {
      const handle = await window.showDirectoryPicker({
        mode: 'readwrite',
        startIn: 'desktop'
      });
      
      setDirectoryHandle(handle);
      setDirectoryPath(handle.name);
      await loadDirectoryContents(handle);
    } catch (error) {
      if (error.name !== 'AbortError') {
        console.error('Error opening directory:', error);
      }
    }
  };

  // Load PDF files from the selected directory (recursive)
  const loadDirectoryContents = async (dirHandle, parentId = 'root') => {
    const children = [];

    try {
      for await (const entry of dirHandle.values()) {
        if (entry.kind === 'directory') {
          const folderId = `folder-${Date.now()}-${Math.random()}`;
          const folder = {
            id: folderId,
            name: entry.name,
            type: 'folder',
            handle: entry,
            children: []
          };
          
          // Recursively load subdirectories
          folder.children = await loadDirectoryContents(entry, folderId);
          children.push(folder);
        } else if (entry.kind === 'file' && entry.name.toLowerCase().endsWith('.pdf')) {
          // Only load PDF files
          const file = await entry.getFile();
          children.push({
            id: `file-${Date.now()}-${Math.random()}`,
            name: entry.name,
            type: 'file',
            fileType: 'application/pdf',
            size: file.size,
            handle: entry,
            lastModified: new Date(file.lastModified).toISOString()
          });
        }
      }
    } catch (error) {
      console.error('Error loading directory contents:', error);
    }

    if (parentId === 'root') {
      setFileTree({
        id: 'root',
        name: dirHandle.name,
        type: 'folder',
        handle: dirHandle,
        children
      });
    }

    return children;
  };



  const findNodeById = (tree, id) => {
    if (tree.id === id) return tree;
    if (tree.children) {
      for (const child of tree.children) {
        const found = findNodeById(child, id);
        if (found) return found;
      }
    }
    return null;
  };

  const findParentById = (tree, id, parent = null) => {
    if (tree.id === id) return parent;
    if (tree.children) {
      for (const child of tree.children) {
        const found = findParentById(child, id, tree);
        if (found) return found;
      }
    }
    return null;
  };

  const addFile = async (parentId, file) => {
    if (!directoryHandle) {
      alert('Please open a folder first using "Open Folder" button.');
      return null;
    }

    // Only allow PDF files
    if (!file.name.toLowerCase().endsWith('.pdf')) {
      alert('Only PDF files are allowed.');
      return null;
    }

    try {
      const parent = findNodeById(fileTree, parentId);
      let targetDirHandle = directoryHandle;

      if (parent && parent.handle && parent.type === 'folder') {
        targetDirHandle = parent.handle;
      }

      // Create the file in the actual file system
      const fileHandle = await targetDirHandle.getFileHandle(file.name, { create: true });
      const writable = await fileHandle.createWritable();
      await writable.write(file.content);
      await writable.close();

      const savedFile = await fileHandle.getFile();

      const newFile = {
        id: `file-${Date.now()}-${Math.random()}`,
        name: file.name,
        type: 'file',
        fileType: 'application/pdf',
        size: savedFile.size,
        handle: fileHandle,
        createdAt: new Date().toISOString()
      };

      setFileTree(prevTree => {
        const newTree = JSON.parse(JSON.stringify(prevTree));
        const parentNode = findNodeById(newTree, parentId);
        if (parentNode && parentNode.type === 'folder') {
          parentNode.children = parentNode.children || [];
          // Don't include the handle in the tree structure for JSON serialization
          const { handle, ...fileWithoutHandle } = newFile;
          parentNode.children.push(fileWithoutHandle);
        }
        return newTree;
      });

      return newFile;
    } catch (error) {
      console.error('Error adding file:', error);
      alert('Failed to create file: ' + error.message);
      return null;
    }
  };

  const addFolder = async (parentId, folderName) => {
    if (!directoryHandle) {
      alert('Please open a folder first using "Open Folder" button.');
      return null;
    }

    try {
      const parent = findNodeById(fileTree, parentId);
      let targetDirHandle = directoryHandle;

      if (parent && parent.handle && parent.type === 'folder') {
        targetDirHandle = parent.handle;
      }

      // Create the folder in the actual file system
      const newDirHandle = await targetDirHandle.getDirectoryHandle(folderName, { create: true });

      const newFolder = {
        id: `folder-${Date.now()}-${Math.random()}`,
        name: folderName,
        type: 'folder',
        handle: newDirHandle,
        children: [],
        createdAt: new Date().toISOString()
      };

      setFileTree(prevTree => {
        const newTree = JSON.parse(JSON.stringify(prevTree));
        const parentNode = findNodeById(newTree, parentId);
        if (parentNode && parentNode.type === 'folder') {
          parentNode.children = parentNode.children || [];
          const { handle, ...folderWithoutHandle } = newFolder;
          parentNode.children.push(folderWithoutHandle);
        }
        return newTree;
      });

      return newFolder;
    } catch (error) {
      console.error('Error adding folder:', error);
      alert('Failed to create folder: ' + error.message);
      return null;
    }
  };

  const deleteNode = async (nodeId) => {
    if (!directoryHandle) {
      alert('Please open a folder first.');
      return;
    }

    try {
      const node = findNodeById(fileTree, nodeId);
      const parent = findParentById(fileTree, nodeId);

      if (node && parent && parent.handle) {
        // Delete from actual file system
        await parent.handle.removeEntry(node.name, { recursive: node.type === 'folder' });

        setFileTree(prevTree => {
          const newTree = JSON.parse(JSON.stringify(prevTree));
          const parentNode = findParentById(newTree, nodeId);
          if (parentNode && parentNode.children) {
            parentNode.children = parentNode.children.filter(child => child.id !== nodeId);
          }
          return newTree;
        });

        // Close the file if it's open
        setOpenFiles(prev => prev.filter(file => file.id !== nodeId));
        if (selectedFile?.id === nodeId) {
          setSelectedFile(null);
        }
      }
    } catch (error) {
      console.error('Error deleting node:', error);
      alert('Failed to delete: ' + error.message);
    }
  };

  const renameNode = async (nodeId, newName) => {
    // Note: File System Access API doesn't support renaming directly
    // This only updates the in-memory tree
    // For actual renaming, you'd need to copy and delete
    alert('Renaming files in the file system is not directly supported. The name will only change in the app view.');
    
    setFileTree(prevTree => {
      const newTree = JSON.parse(JSON.stringify(prevTree));
      const node = findNodeById(newTree, nodeId);
      if (node) {
        node.name = newName;
      }
      return newTree;
    });
  };

  const moveNode = async (nodeId, targetParentId) => {
    // Note: Moving files requires copying and deleting
    // This is complex with File System Access API
    alert('Moving files in the file system is not supported yet. Use your file explorer to move files, then reload the folder.');
    
    // Keep for in-memory operations
    setFileTree(prevTree => {
      const newTree = JSON.parse(JSON.stringify(prevTree));
      
      const node = findNodeById(newTree, nodeId);
      if (!node) return prevTree;

      const currentParent = findParentById(newTree, nodeId);
      if (currentParent && currentParent.children) {
        currentParent.children = currentParent.children.filter(child => child.id !== nodeId);
      }

      const targetParent = findNodeById(newTree, targetParentId);
      if (targetParent && targetParent.type === 'folder') {
        targetParent.children = targetParent.children || [];
        targetParent.children.push(node);
      }

      return newTree;
    });
  };

  const openFile = async (file) => {
    try {
      // If file has a handle, read from the actual file system
      if (file.handle) {
        const actualFile = await file.handle.getFile();
        const content = await actualFile.arrayBuffer();
        
        const fileWithContent = {
          ...file,
          content,
          url: URL.createObjectURL(actualFile)
        };
        
        setSelectedFile(fileWithContent);
        if (!openFiles.find(f => f.id === file.id)) {
          setOpenFiles(prev => [...prev, fileWithContent]);
        }
      } else {
        // Fallback for in-memory files
        setSelectedFile(file);
        if (!openFiles.find(f => f.id === file.id)) {
          setOpenFiles(prev => [...prev, file]);
        }
      }
    } catch (error) {
      console.error('Error opening file:', error);
      alert('Failed to open file: ' + error.message);
    }
  };

  const closeFile = (fileId) => {
    // Clean up URL if it exists
    const file = openFiles.find(f => f.id === fileId);
    if (file?.url) {
      URL.revokeObjectURL(file.url);
    }

    setOpenFiles(prev => prev.filter(f => f.id !== fileId));
    if (selectedFile?.id === fileId) {
      const remaining = openFiles.filter(f => f.id !== fileId);
      setSelectedFile(remaining[remaining.length - 1] || null);
    }
  };

  const updateFileContent = async (fileId, content) => {
    try {
      const file = findNodeById(fileTree, fileId);
      
      if (file && file.handle) {
        // Write to actual file system
        const writable = await file.handle.createWritable();
        await writable.write(content);
        await writable.close();

        // Update in-memory state
        setOpenFiles(prev => 
          prev.map(f => f.id === fileId ? { ...f, content } : f)
        );

        if (selectedFile?.id === fileId) {
          setSelectedFile(prev => ({ ...prev, content }));
        }
      }
    } catch (error) {
      console.error('Error updating file:', error);
      alert('Failed to save file: ' + error.message);
    }
  };

  // Download a file from the dashboard to PC
  const downloadFile = (file) => {
    if (file.url) {
      const a = document.createElement('a');
      a.href = file.url;
      a.download = file.name;
      a.click();
    } else if (file.content) {
      const blob = new Blob([file.content]);
      const url = URL.createObjectURL(blob);
      const a = document.createElement('a');
      a.href = url;
      a.download = file.name;
      a.click();
      URL.revokeObjectURL(url);
    }
  };

  const addCitation = (citation) => {
    setCitations(prev => [...prev, { ...citation, id: `citation-${Date.now()}` }]);
  };

  const deleteCitation = (citationId) => {
    setCitations(prev => prev.filter(c => c.id !== citationId));
  };

  const value = {
    fileTree,
    selectedFile,
    openFiles,
    citations,
    directoryHandle,
    directoryPath,
    isFileSystemAccessSupported,
    openDirectory,
    loadDirectoryContents,
    addFile,
    addFolder,
    deleteNode,
    renameNode,
    moveNode,
    openFile,
    closeFile,
    updateFileContent,
    downloadFile,
    addCitation,
    deleteCitation,
    findNodeById
  };

  return (
    <FileSystemContext.Provider value={value}>
      {children}
    </FileSystemContext.Provider>
  );
};
